"engine": {
    "defaultModel": "gemini-2.0-flash",
    "defaultThinkingBudget": 512,
    "temperature": 0.7,
    "_kernelExport": {
      "_description": "הגדרת האם kernel הוא חלק מה-System Prompt המלא",
      "includeInSystemPrompt": true
    },
    "kernel": {
      "version": "1.0",
      "effortRegulation": true,
      "binding": {
        "contextEnforcement": {
          "learning": {
            "diagnostic": {
              "noFullSolution": false,
              "processIntegrity": "strict",
              "effortRegulation": "minimal",
              "guidedSelfCorrection": "disabled"
            },
            "development": {
              "noFullSolution": true,
              "processIntegrity": "strict",
              "effortRegulation": "strict",
              "guidedSelfCorrection": "strict"
            },
            "reflection": {
              "noFullSolution": true,
              "processIntegrity": "soft",
              "effortRegulation": "adaptive",
              "guidedSelfCorrection": "optional"
            }
          },
          "teaching": {
            "design": {
              "noFullSolution": false,
              "effortRegulation": "minimal"
            }
          },
          "institutional": {
            "analytics": {
              "noFullSolution": false
            }
          }
        }
      },
      "private": {
        "invisibleEffortRegulation": true
      }
    }
  }
