# Gatekeeping strict test environment template
# Copy values into your active shell or CI secret store.

# Firebase
FIREBASE_DB_URL=https://miled-one-classroom-default-rtdb.europe-west1.firebasedatabase.app

# Strict evaluator auth
GATEKEEPING_BEARER_TOKEN=
GATEKEEPING_ACTOR_ID=
GATEKEEPING_ACTOR_ROLE=lecturer

# Test targeting
GATEKEEPING_BASE_URL=http://localhost:8888/.netlify/functions
GATEKEEPING_TEST_COURSE_ID=course_integration_test
GATEKEEPING_TEST_STUDENT_ID=
GATEKEEPING_TEST_STAGE_ID=stage_integration

# Webhook strict check
GATEKEEPING_WEBHOOK_SECRET=

# Keep false in strict mode
GATEKEEPING_ALLOW_LEGACY_ACTOR=false
